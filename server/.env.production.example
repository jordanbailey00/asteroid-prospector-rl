# M9 production backend env template (do not commit real secrets)

# Path where training/eval run artifacts are stored on the backend host.
ABP_RUNS_ROOT=/var/lib/abp/runs

# Explicit frontend origins allowed by CORS (comma-separated, no trailing slash).
ABP_CORS_ORIGINS=https://<your-vercel-domain>,https://<your-preview-domain>

# Optional wildcard for Vercel previews.
ABP_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Default W&B scope for proxy endpoints.
ABP_WANDB_ENTITY=<wandb-entity>
ABP_WANDB_PROJECT=<wandb-project>

# Server-side secret only. Set through host secret manager.
WANDB_API_KEY=<wandb-api-key>

# W&B proxy cache TTL in seconds.
ABP_WANDB_CACHE_TTL_SECONDS=30
